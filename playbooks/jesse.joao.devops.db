$TTL 86400
@ IN SOA dns.jesse.joao.devops. root.jesse.joao.devops. (
  2025082501 ; Serial
  3600       ; Refresh
  1800       ; Retry
  604800     ; Expire
  86400      ; Minimum TTL
)

  IN NS dns.jesse.joao.devops.
  IN MX 10 dns.jesse.joao.devops.

; Registros A (Hosts)
arq IN A 192.168.56.109
db  IN A 192.168.56.134
app IN A 192.168.56.194

; Aliases (CNAME) para atender aos testes do PDF
dns IN CNAME arq
www IN CNAME app
